# Copy to claude-review.yml only after reviewing permissions and configuring
# the official Claude GitHub App or a repository-scoped custom GitHub App.
name: Claude Review
on:
  issue_comment:
    types: [created]
permissions:
  contents: read
  pull-requests: write
  issues: write
jobs:
  claude:
    if: contains(github.event.comment.body, '@claude')
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      # - uses: anthropics/claude-code-action@v1
      #   with:
      #     github_token: ${{ secrets.CLAUDE_GITHUB_TOKEN }}
      #     claude_args: '--max-turns 10'
